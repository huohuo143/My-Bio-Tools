<Window x:Class="MyBioTools.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="My Bio Tools"
        Width="1280"
        Height="820"
        MinWidth="960"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Icon="Assets/AppIcon.ico"
        Background="#F7F9FC"
        Loaded="Window_Loaded"
        Closed="Window_Closed"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Grid>
        <Grid x:Name="LaunchPanel">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F8FAFC" Offset="0" />
                    <GradientStop Color="#E9F5F3" Offset="1" />
                </LinearGradientBrush>
            </Grid.Background>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="520">
                <Border Width="132" Height="132" CornerRadius="28" Background="White"
                        HorizontalAlignment="Center" Margin="0,0,0,22">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="28" ShadowDepth="8" Opacity="0.12" />
                    </Border.Effect>
                    <Image Source="Assets/AppIcon-1024.png" Width="100" Height="100" Stretch="Uniform" />
                </Border>
                <TextBlock Text="My Bio Tools" FontFamily="Segoe UI Variable Display, Segoe UI"
                           FontSize="34" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}"
                           TextAlignment="Center" />
                <TextBlock Text="正在准备本地科研分析环境" FontSize="18" FontWeight="SemiBold"
                           Foreground="{StaticResource InkBrush}" TextAlignment="Center" Margin="0,10,0,0" />
                <TextBlock Text="加载 Python、Streamlit 与内置水稻注释数据"
                           FontSize="14" Foreground="{StaticResource MutedBrush}"
                           TextAlignment="Center" Margin="0,6,0,22" />
                <ProgressBar IsIndeterminate="True" Height="5" Width="260"
                             Foreground="{StaticResource AccentBrush}" Background="#D8E8E5"
                             HorizontalAlignment="Center" />
                <TextBlock Text="🔒  数据默认仅在本机处理" FontSize="12"
                           Foreground="{StaticResource MutedBrush}" TextAlignment="Center" Margin="0,20,0,0" />
            </StackPanel>
        </Grid>

        <Grid x:Name="AuthPanel" Visibility="Collapsed">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F8FAFC" Offset="0" />
                    <GradientStop Color="#E9F5F3" Offset="1" />
                </LinearGradientBrush>
            </Grid.Background>
            <Grid Margin="56">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="430" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Width="480" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image Source="Assets/AppIcon-1024.png" Width="104" Height="104" HorizontalAlignment="Left" />
                    <TextBlock Text="My Bio Tools" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" Margin="0,18,0,6" />
                    <TextBlock Text="课题组内部科研分析工具" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
                    <TextBlock Text="✓ 账号须经管理员审核&#x0a;✓ 分析文件和结果默认只在本机处理&#x0a;✓ 每个账号最多 2 台设备，支持 7 天离线使用"
                               FontSize="14" LineHeight="30" Foreground="{StaticResource MutedBrush}" Margin="0,24,0,0" />
                </StackPanel>
                <Border Grid.Column="1" Background="White" CornerRadius="18" Padding="28" VerticalAlignment="Center">
                    <Border.Effect><DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.12" /></Border.Effect>
                    <StackPanel>
                        <TabControl x:Name="AuthTabs">
                            <TabItem Header="登录">
                                <StackPanel Margin="4,18,4,4">
                                    <TextBlock Text="邮箱" FontWeight="SemiBold" />
                                    <TextBox x:Name="LoginEmailBox" Margin="0,6,0,12" Padding="9" />
                                    <TextBlock Text="密码" FontWeight="SemiBold" />
                                    <PasswordBox x:Name="LoginPasswordBox" Margin="0,6,0,16" Padding="9" />
                                    <Button x:Name="LoginButton" Content="登录" Style="{StaticResource PrimaryButton}" Click="LoginButton_Click" />
                                    <Button Content="忘记密码" Click="ForgotPasswordButton_Click" Margin="0,8,0,0" />
                                    <Button Content="重发验证邮件" Click="ResendVerificationButton_Click" Margin="0,6,0,0" />
                                </StackPanel>
                            </TabItem>
                            <TabItem Header="注册">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="430">
                                    <StackPanel Margin="4,18,4,4">
                                        <TextBlock Text="邮箱" FontWeight="SemiBold" /><TextBox x:Name="RegisterEmailBox" Margin="0,6,0,10" Padding="8" />
                                        <TextBlock Text="真实姓名" FontWeight="SemiBold" /><TextBox x:Name="RegisterNameBox" Margin="0,6,0,10" Padding="8" />
                                        <TextBlock Text="课题组身份" FontWeight="SemiBold" />
                                        <ComboBox x:Name="RegisterRoleBox" SelectedIndex="3" Margin="0,6,0,10" Padding="8">
                                            <ComboBoxItem Content="导师" /><ComboBoxItem Content="博士后" /><ComboBoxItem Content="博士研究生" />
                                            <ComboBoxItem Content="硕士研究生" /><ComboBoxItem Content="本科生" /><ComboBoxItem Content="其他" />
                                        </ComboBox>
                                        <TextBlock Text="申请说明" FontWeight="SemiBold" /><TextBox x:Name="RegisterNoteBox" Margin="0,6,0,10" Padding="8" Height="58" TextWrapping="Wrap" AcceptsReturn="True" />
                                        <TextBlock Text="密码（至少 12 个字符）" FontWeight="SemiBold" /><PasswordBox x:Name="RegisterPasswordBox" Margin="0,6,0,10" Padding="8" />
                                        <TextBlock Text="确认密码" FontWeight="SemiBold" /><PasswordBox x:Name="RegisterConfirmBox" Margin="0,6,0,14" Padding="8" />
                                        <Button x:Name="RegisterButton" Content="提交注册申请" Style="{StaticResource PrimaryButton}" Click="RegisterButton_Click" />
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                        <TextBlock x:Name="AuthMessageText" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" Margin="4,14,4,0" />
                        <ProgressBar x:Name="AuthProgress" IsIndeterminate="True" Height="4" Visibility="Collapsed" Margin="4,12,4,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Grid x:Name="ReadyPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#F2F5F8" BorderBrush="#DDE3EA" BorderThickness="0,0,0,1">
                <Grid Margin="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Fill="#22A06B" Width="8" Height="8" Margin="0,0,9,0" />
                        <TextBlock Text="分析环境已就绪" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource InkBrush}" VerticalAlignment="Center" />
                        <TextBlock x:Name="StartupDurationText" FontSize="11"
                                   Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center" Margin="8,0,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="RefreshButton" Content="⟳  刷新" Click="RefreshButton_Click"
                                ToolTip="刷新当前工具（Ctrl+R）" Padding="10,4" MinHeight="28" Margin="0,0,6,0" />
                        <Button x:Name="RestartButton" Content="重新启动服务" Click="RestartButton_Click"
                                ToolTip="重新启动内置服务（Ctrl+Shift+R）" Padding="10,4" MinHeight="28" Margin="0,0,6,0" />
                        <Button Content="打开运行日志" Click="OpenLogButton_Click"
                                ToolTip="打开运行日志（Ctrl+Shift+L）" Padding="10,4" MinHeight="28" />
                        <TextBlock x:Name="AccountEmailText" VerticalAlignment="Center" Margin="14,0,6,0" Foreground="{StaticResource MutedBrush}" />
                        <Button Content="账号" Click="AccountButton_Click" Padding="10,4" MinHeight="28" />
                    </StackPanel>
                </Grid>
            </Border>
            <wv2:WebView2 x:Name="Browser" Grid.Row="1" DefaultBackgroundColor="#F7F9FC" />
        </Grid>

        <Grid x:Name="FailurePanel" Visibility="Collapsed" Background="#F7F9FC">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="760">
                <TextBlock Text="⚠" FontSize="46" Foreground="#D97706" TextAlignment="Center" />
                <TextBlock Text="分析环境启动失败" FontSize="25" FontWeight="Bold"
                           Foreground="{StaticResource InkBrush}" TextAlignment="Center" Margin="0,14,0,0" />
                <TextBlock x:Name="FailureMessageText" FontSize="14" Foreground="{StaticResource MutedBrush}"
                           TextAlignment="Center" TextWrapping="Wrap" Margin="0,12,0,18" />
                <Expander x:Name="FailureDetailsExpander" Header="查看技术详情" Width="720" Margin="0,0,0,18">
                    <TextBox x:Name="FailureDetailsText" Height="220" Padding="12"
                             FontFamily="Cascadia Mono, Consolas" FontSize="11"
                             IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             Background="#EEF2F6" BorderBrush="#D8DEE7" />
                </Expander>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="打开运行日志" Click="OpenLogButton_Click" Margin="0,0,10,0" />
                    <Button Content="重新启动" Style="{StaticResource PrimaryButton}" Click="RestartButton_Click" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <Grid x:Name="RuntimePanel" Visibility="Collapsed" Background="#F7F9FC">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="640">
                <TextBlock Text="🌐" FontSize="44" TextAlignment="Center" />
                <TextBlock Text="需要 Microsoft Edge WebView2 Runtime" FontSize="24" FontWeight="Bold"
                           Foreground="{StaticResource InkBrush}" TextAlignment="Center" Margin="0,14,0,0" />
                <TextBlock x:Name="RuntimeMessageText"
                           Text="APP 已附带微软官方离线安装程序。安装后即可在本机窗口中运行全部工具。"
                           FontSize="14" Foreground="{StaticResource MutedBrush}" TextAlignment="Center"
                           TextWrapping="Wrap" Margin="0,12,0,20" />
                <Button x:Name="InstallRuntimeButton" Content="安装 WebView2 Runtime"
                        Style="{StaticResource PrimaryButton}" Click="InstallRuntimeButton_Click"
                        HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
